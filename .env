# Server Configuration
PORT=3101
HOST=0.0.0.0
NETWORK_IP=192.168.18.32

# MongoDB Configuration
MONGO_URI=mongodb://127.0.0.1:27017/ShopApp

# WebSocket Configuration
WEBSOCKET_PORT=3101
WEBSOCKET_HOST=0.0.0.0
