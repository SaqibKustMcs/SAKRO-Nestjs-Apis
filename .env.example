# Server
PORT=3000
HOST=0.0.0.0
NETWORK_IP=localhost

# Database (MongoDB Atlas). On Render: Network Access → allow 0.0.0.0/0 (or Render static egress IPs).
# URL-encode special characters in the password (@ → %40, etc.).
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# Optional app URLs
API_BASE_URL=http://localhost:3000
URL=http://localhost:3000/

# Firebase Admin (FCM) — use ONE of these (required on Render; file is not in git):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}   # minified one-line JSON
# FIREBASE_SERVICE_ACCOUNT_BASE64=...                              # base64 of the JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./jhamat-app-firebase-adminsdk-fbsvc-686f30ea30.json
